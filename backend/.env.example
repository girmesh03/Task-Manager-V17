# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=4000

# Database
MONGODB_URI=mongodb://localhost:27017/task-management

# JWT Secrets (generate secure random strings for production)
JWT_ACCESS_SECRET=your-access-token-secret-key-here
JWT_REFRESH_SECRET=your-refresh-token-secret-key-here

# JWT Expiration
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:5173

# Email Configuration (optional - for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=Task Management <noreply@taskmanagement.com>

# Cloudinary (optional - for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Platform Organization (for system administration)
PLATFORM_ORG=platform-org-id-here

# Seed Data (set to true to initialize with mock data)
INITIALIZE_SEED_DATA=false
